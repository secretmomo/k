{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },

  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "cSpell.words": [
    "apidata",
    "bunx",
    "checkin",
    "Datas",
    "eastmoney",
    "fcol",
    "jdzf",
    "jdzfnew",
    "KHTML",
    "larksuiteoapi",
    "notionhq",
    "wathet",
    "Xueqiu"
  ]
}
